<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    
    <h1>Gerenciar Carros</h1>
    <table border="1">
        <tr>
            <th>Nome</th>
            <th>Modelo</th>
            <th>Quantidade</th>
        </tr>
        <% carros.forEach(function(carro) { %>
            <tr>
                <td><%= carro.nome %></td>
                <td><%= carro.modelo %></td>
                <td><%= carro.quantidade %></td>
            </tr>
        <% }); %>
    </table>
</body>
</html>